export PATH=$PATH:$HOME/appimages
export PATH=$PATH:/snap/bin
export PATH=$HOME/.local/bin:$PATH
export PATH=$HOME/.cargo/bin:$PATH
export PATH=$HOME/.local/go/bin:$PATH

export CC=clang
export CXX=clang++

# start ssh-agent (prefer keychain for session persistence)
if command -v keychain > /dev/null 2>&1; then
  eval "$(keychain --eval --quiet --agents ssh $(ls ~/.ssh/id_* 2>/dev/null | grep -v '\.pub$' | tr '\n' ' '))"
elif [ -z "$SSH_AUTH_SOCK" ]; then
  eval "$(ssh-agent -s)" > /dev/null
fi

# source machine specific config
if [ -f $HOME/.posixrc.local ]; then
  source $HOME/.posixrc.local
fi

# source nvm (for node.js)
if [ -f $HOME/.nvm/nvm.sh ]; then
  source $HOME/.nvm/nvm.sh
fi

# for cline llm agent
if [ "$CLINE_ACTIVE" = "true" ]; then
  export PAGER=cat
fi
